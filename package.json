{
  "name": "mlb-realtime-second-screen-dashboard",
  "version": "1.0.0",
  "description": "A browser-first MLB realtime second-screen dashboard for following one favorite team during live games.",
  "main": "app.js",
  "scripts": {
    "check:app": "node --check app.js",
    "check:worker": "node --check mlb-worker.js",
    "check": "npm run check:app && npm run check:worker",
    "smoke:pregame": "node .\\smoke-live.cjs pregame .smoke\\pregame-state.png 141",
    "smoke:live": "node .\\smoke-live.cjs live .smoke\\live-state.png 141",
    "smoke:final": "node .\\smoke-live.cjs final .smoke\\final-state.png 141",
    "smoke:dom": "powershell -ExecutionPolicy Bypass -File .\\smoke-test.ps1"
  },
  "keywords": [
    "mlb",
    "baseball",
    "dashboard",
    "second-screen",
    "sports",
    "realtime"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "playwright-core": "^1.59.1"
  }
}
